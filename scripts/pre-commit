#!/bin/bash
# pre-commit hook - catches common agent mistakes before commit
#
# Install: cp scripts/pre-commit .git/hooks/pre-commit && chmod +x .git/hooks/pre-commit
# Or:      ln -sf ../../scripts/pre-commit .git/hooks/pre-commit

set -euo pipefail

RED='\033[0;31m'
YELLOW='\033[1;33m'
NC='\033[0m' # No Color

ERRORS=0
WARNINGS=0

# Get staged files
STAGED_FILES=$(git diff --cached --name-only --diff-filter=ACM)

if [[ -z "$STAGED_FILES" ]]; then
    exit 0
fi

echo "Running pre-commit checks..."

# Check for debug statements
check_debug_statements() {
    local patterns=(
        'console\.log\('
        'print\('           # Python - may have false positives, but agents overuse this
        'fmt\.Println\('    # Go debug prints
        'dbg!\('            # Rust debug macro
        'debugger;'         # JS debugger
        'binding\.pry'      # Ruby debugger
        'import pdb'        # Python debugger
    )

    for pattern in "${patterns[@]}"; do
        if git diff --cached | grep -E "^\+" | grep -qE "$pattern"; then
            echo -e "${YELLOW}WARNING: Possible debug statement found: $pattern${NC}"
            git diff --cached | grep -E "^\+.*$pattern" | head -3
            ((WARNINGS++)) || true
        fi
    done
}

# Check for TODO/FIXME markers that might indicate incomplete work
check_incomplete_markers() {
    if git diff --cached | grep -E "^\+" | grep -qiE '(TODO|FIXME|XXX|HACK):'; then
        echo -e "${YELLOW}WARNING: New TODO/FIXME markers added${NC}"
        git diff --cached | grep -E "^\+.*(TODO|FIXME|XXX|HACK):" | head -5
        ((WARNINGS++)) || true
    fi
}

# Check for secrets/credentials
check_secrets() {
    local patterns=(
        'password\s*=\s*["\x27][^"\x27]+'
        'api_key\s*=\s*["\x27][^"\x27]+'
        'secret\s*=\s*["\x27][^"\x27]+'
        'AWS_SECRET'
        'PRIVATE_KEY'
        'BEGIN RSA PRIVATE KEY'
        'BEGIN OPENSSH PRIVATE KEY'
    )

    for pattern in "${patterns[@]}"; do
        if git diff --cached | grep -E "^\+" | grep -qiE "$pattern"; then
            echo -e "${RED}ERROR: Possible secret/credential found: $pattern${NC}"
            ((ERRORS++)) || true
        fi
    done
}

# Check for large files
check_large_files() {
    local max_size=1048576  # 1MB
    for file in $STAGED_FILES; do
        if [[ -f "$file" ]]; then
            size=$(wc -c < "$file" 2>/dev/null || echo 0)
            if [[ $size -gt $max_size ]]; then
                echo -e "${YELLOW}WARNING: Large file staged: $file ($(numfmt --to=iec $size))${NC}"
                ((WARNINGS++)) || true
            fi
        fi
    done
}

# Check for merge conflict markers
check_conflict_markers() {
    if git diff --cached | grep -qE '^(\+<<<<<<|\+======|\+>>>>>>)'; then
        echo -e "${RED}ERROR: Merge conflict markers found${NC}"
        ((ERRORS++)) || true
    fi
}

# Run all checks
check_debug_statements
check_incomplete_markers
check_secrets
check_large_files
check_conflict_markers

# Summary
echo ""
if [[ $ERRORS -gt 0 ]]; then
    echo -e "${RED}Pre-commit failed: $ERRORS error(s), $WARNINGS warning(s)${NC}"
    echo "Fix errors before committing. Use 'git commit --no-verify' to bypass (not recommended)."
    exit 1
elif [[ $WARNINGS -gt 0 ]]; then
    echo -e "${YELLOW}Pre-commit passed with $WARNINGS warning(s)${NC}"
    exit 0
else
    echo "Pre-commit checks passed."
    exit 0
fi
