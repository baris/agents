# Telegram Bot API Configuration
TELEGRAM_BOT_TOKEN=your_telegram_bot_token_here

# Security Whitelisting
# Numeric user ID of the whitelisted Telegram user allowed to issue commands
WHITELISTED_USER_ID=123456789

# Topic Routing
# Set to true to route prompts to specific subdirectories based on message_thread_id
USE_TOPICS=true
TOPIC_MAPPINGS_FILE=topic_mappings.json

# Default workspace directory if USE_TOPICS is false or no topic mapping matches
DEFAULT_WORKSPACE_DIR=/Users/tbmetin/repos/agents
